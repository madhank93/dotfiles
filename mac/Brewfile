# ── Runtime Manager ───────────────────────────────────────────────────────────

brew "mise"                        # 2026.5.15 — universal version manager
                                   # manages: node, python, go (see .config/mise/config.toml)
                                   # replaces: nvm, pyenv, goenv

# brew keeps these installed as deps for: cdk8s, typescript, awscli, nmap, yt-dlp
# DO NOT uninstall — mise shims shadow them on PATH automatically
brew "node"                        # brew dep only — PATH controlled by mise
brew "python@3.13"                 # brew dep only — PATH controlled by mise
brew "go"                          # brew dep only — PATH controlled by mise

# ── Terminal Multiplexer ──────────────────────────────────────────────────────

brew "zellij"                      # terminal workspace / multiplexer (config in .config/zellij/)

