cask "raycast"                     # spotlight replacement — cmd+space launcher
cask "karabiner-elements"          # keyboard remapping (capslock → hyper)
cask "aerospace"                   # tiling window manager
cask "bitwarden"                   # password manager
cask "orbstack"                    # docker runtime (OrbStack already active — docker-desktop safe to remove)
cask "visual-studio-code"          # editor
cask "cursor"                      # AI editor
cask "claude"                      # Claude desktop app
cask "obs"                         # screen recording / streaming
cask "shottr"                      # screenshot tool
cask "spotify"                     # music
cask "telegram"                    # messaging
